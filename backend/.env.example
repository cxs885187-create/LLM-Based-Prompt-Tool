# Database (SQLite mode ignores MySQL fields)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=experiment_db
DATABASE_URL=sqlite:///./test.db

# LLM provider (GLM-4)
AIGC_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
AIGC_API_KEY=your_glm_api_key_here
AIGC_MODEL=glm-4-flash
USE_MOCK_LLM=false
LLM_TIMEOUT_SECONDS=8
LLM_CONNECT_TIMEOUT_SECONDS=3
LLM_RETRIES=1
LLM_FAILURE_THRESHOLD=3
LLM_COOLDOWN_SECONDS=45
LLM_MAX_CONCURRENCY=8

# App security
SECRET_KEY=your_secret_key_for_jwt_or_other
ADMIN_TOKEN=your_strong_admin_token

# CORS
CORS_ORIGINS=http://localhost:5173
